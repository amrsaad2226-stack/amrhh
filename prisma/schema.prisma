
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  latitude   Float
  longitude  Float
  address    String?
  employees  Employee[]
}

model Employee {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  name             String
  password         String
  deviceId         String?  @unique
  role             Role     @default(EMPLOYEE)
  
  branchId         Int?
  branch           Branch?  @relation(fields: [branchId], references: [id])
  isAnyBranch      Boolean  @default(false)

  dailyHours       Int      @default(10)
  dailySalary      Float
  overtimeRate     Float    @default(1.0)
  department       String
  allowDist        Int      @default(50)

  // New field for Salary Type
  salaryType       SalaryType @default(MONTHLY)

  offDay           String   @default("NONE")
  offDayHours      Int      @default(0)
  timeIn           String   @default("09:00")
  timeOut          String   @default("17:00")
  
  createdAt        DateTime @default(now())
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  cashTransactions CashTransaction[]
}

model Attendance {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  
  checkIn       DateTime? 
  checkOut      DateTime? 
  
  latIn         Float?
  lngIn         Float?
  latOut        Float?
  lngOut        Float?
  
  status        String?   
  
  requiredHours Int      @default(10) 
  duration      Float    @default(0)
  overtime      Float    @default(0)

  employeeId    Int
  employee      Employee @relation(fields: [employeeId], references: [id])
}

enum Role {
  ADMIN
  EMPLOYEE
}

// Enum for Salary Type
enum SalaryType {
  DAILY
  WEEKLY
  MONTHLY
}

model LeaveRequest {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id])
  startDate    DateTime
  endDate      DateTime
  type         String
  reason       String?
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
}

model CashTransaction {
  id          Int      @id @default(autoincrement())
  type        CashType
  amount      Float
  note        String?

  employeeId  Int?
  employee    Employee? @relation(fields: [employeeId], references: [id])

  createdAt   DateTime @default(now())
}

enum CashType {
  INCOME
  OUTCOME
}
