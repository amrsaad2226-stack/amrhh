generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 1. جدول الفروع
model Branch {
  id         Int        @id @default(autoincrement())
  name       String     @unique // اسم الفرع
  latitude   Float
  longitude  Float
  address    String?
  employees  Employee[] // علاقة مع الموظفين
}

// 2. تحديث جدول الموظفين
model Employee {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  name             String
  password         String
  deviceId         String?  @unique
  role             Role     @default(EMPLOYEE)
  
  // نظام الفروع الجديد
  branchId         Int?     // الفرع المحدد (اختياري لو "مفتوح")
  branch           Branch?  @relation(fields: [branchId], references: [id])
  isAnyBranch      Boolean  @default(false) // يحق له الحضور في أي فرع

  // الحسابات المالية والإضافي
  dailyHours       Int      @default(10)
  dailySalary      Float
  overtimeRate     Float    @default(1.0)  // معامل حساب الإضافي (الافتراضي 1)
  department       String

  // نظام الإجازات والمواعيد
  offDay           String   @default("NONE") // السبت، الأحد... أو NONE
  offDayHours      Int      @default(0)      // عدد الساعات الإلزامية في يوم الإجازة
  timeIn           String   @default("09:00")
  timeOut          String   @default("17:00")
  
  createdAt        DateTime @default(now())
  attendances      Attendance[]
}

// 3. جدول سجلات الحضور والانصراف اليومية
model Attendance {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  
  checkIn     DateTime? // وقت الدخول الفعلي
  checkOut    DateTime? // وقت الخروج الفعلي
  
  // تخزين الموقع الذي تم منه البصمة فعلياً للتأكد
  latIn       Float?
  lngIn       Float?
  
  status      String?   // (Present, Late, Absent)
  overtime    Int       @default(0) // عدد الدقائق الإضافية
  
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date]) // منع تسجيل دخول مرتين لنفس الموظف في نفس اليوم
}

enum Role {
  ADMIN
  EMPLOYEE
}
