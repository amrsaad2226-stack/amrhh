generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. جدول الفروع
model Branch {
  id         Int        @id @default(autoincrement())
  name       String     @unique // اسم الفرع
  latitude   Float
  longitude  Float
  address    String?
  employees  Employee[] // علاقة مع الموظفين
}

// 2. تحديث جدول الموظفين
model Employee {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  name             String
  password         String
  deviceId         String?  @unique
  role             Role     @default(EMPLOYEE)
  
  // نظام الفروع الجديد
  branchId         Int?     // الفرع المحدد (اختياري لو "مفتوح")
  branch           Branch?  @relation(fields: [branchId], references: [id])
  isAnyBranch      Boolean  @default(false) // يحق له الحضور في أي فرع

  // الحسابات المالية والإضافي
  dailyHours       Int      @default(10)
  dailySalary      Float
  overtimeRate     Float    @default(1.0)  // معامل حساب الإضافي (الافتراضي 1)
  department       String
  allowDist        Int      @default(50)

  // نظام الإجازات والمواعيد
  offDay           String   @default("NONE") // السبت، الأحد... أو NONE
  offDayHours      Int      @default(0)      // عدد الساعات الإلزامية في يوم الإجازة
  timeIn           String   @default("09:00")
  timeOut          String   @default("17:00")
  
  createdAt        DateTime @default(now())
  attendances      Attendance[]
}

// 3. جدول سجلات الحضور والانصراف اليومية
model Attendance {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  
  checkIn       DateTime? 
  checkOut      DateTime? 
  
  latIn         Float?
  lngIn         Float?
  latOut        Float?
  lngOut        Float?
  
  status        String?   
  
  requiredHours Int      @default(10) 
  overtime      Float    @default(0)

  employeeId    Int
  employee      Employee @relation(fields: [employeeId], references: [id])
}

enum Role {
  ADMIN
  EMPLOYEE
}
